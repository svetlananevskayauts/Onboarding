# Airtable Configuration
AIRTABLE_API_KEY=your_airtable_api_key_here
AIRTABLE_BASE_ID=your_base_id_here

# Table IDs
UTS_STARTUPS_TABLE_ID=your_startups_table_id
TEAM_MEMBERS_TABLE_ID=your_team_members_table_id
UTS_EOI_TABLE_ID=your_eoi_table_id

# Agent + Transactions Base (membership management)
AIRTABLE_AGENT_PAT=your_agent_pat
AIRTABLE_AGENT_BASE_ID=appRypIQ9OdR0ilGL
AGENT_TEAM_MEMBERS_TABLE_ID=tblaqviciPbDyKIZR
AGENT_MEMBERSHIP_EVENTS_TABLE_ID=tbla36dy2z5cPmVpY
AGENT_CHANGE_REQUESTS_TABLE_ID=tbloSfeIqOZyCJrwy
AGENT_MEMBERSHIP_TYPES_TABLE_ID=tblEYO4C1ybIaNoEL
AGENT_UTS_STARTUPS_TABLE_ID=tbl1Jumidao9VffEw
AGENT_FINANCIAL_TRANSACTIONS_TABLE_ID=tbl8cyTgDN8iE7fFq
FINANCIAL_TRANSACTIONS_CACHE_MS=300000
FINANCIAL_TRANSACTIONS_LIMIT=200

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_here

# Environment
# Preferred dev/prod flag for this app:
#   NODE_DEV=dev   → enables development behaviors (local links, dev helper routes)
#   NODE_DEV=prod  → production mode
NODE_DEV=dev
# Legacy/Node flag still supported as fallback:
NODE_ENV=production

# Airtable Form URLs (prefilled)
STARTUP_ONBOARDING_FORM_URL=https://airtable.com/your_startup_form_url
TEAM_MEMBER_FORM_URL=https://airtable.com/your_team_member_form_url

# Server Configuration
PORT=3000 

# PDF Generation
# Base URL resolution: uses https://REPLIT_DEV_DOMAIN when set. In development, you can set an ngrok URL
# via DEV_PUBLIC_BASE_URL for Airtable ingestion.
DEV_PUBLIC_BASE_URL=
REPLIT_DEV_DOMAIN=
# Airtable field overrides (optional; defaults shown)
# Attachment field to store UNSIGNED agreement
AIRTABLE_UNSIGNED_AGREEMENT_FIELD=Agreement
# Date field to stamp when UNSIGNED agreement is created
AIRTABLE_UNSIGNED_AGREEMENT_DATE_FIELD=Agreement Created Date
# Attachment field to store SIGNED agreement (falls back to Agreement if missing)
AIRTABLE_SIGNED_AGREEMENT_FIELD=Signed Agreement
# Date field to stamp when SIGNED agreement is received
AIRTABLE_SIGNED_AGREEMENT_DATE_FIELD=Signed Agreement Received Date
# Team Members manual override (non-empty bypasses SKY validation)
AIRTABLE_MEMBERS_MANUAL_OVERRIDE_FIELD=Manual Discount Check
# Manual Discount Category field (used for pricing/calculation when manual override is present)
AIRTABLE_MEMBERS_MANUAL_DISCOUNT_CATEGORY_FIELD=Manual Discount Category
# Team member role/title field (editable via dashboard)
AIRTABLE_MEMBERS_ROLE_FIELD=Position at startup*
# TTL in seconds for /download links (default 3600)
URL_TTL_SECONDS=3600
# Optional P12 certificate for server-side signing of UTS block
P12_PATH=
P12_PASSPHRASE=
# Agreement Terms URL used inside the generated PDF
TERMS_URL=https://uts.ac/UTSS_TermsAndConditions
# Internal auth token for privileged endpoints (use a secure random value)
AUTH_TOKEN=change_me_internal_token

# Development (legacy toggle; prefer NODE_DEV)
# Enable dev behaviors (show magic links on the landing page, allow fake validation, save local PDFs)
# DEV_MODE=1
# When DEV_MODE=1 and SKY credentials are missing, fake validation is auto-enabled.
# You can also force it explicitly:
DEV_FAKE_VALIDATION=1

# SKY API (for real validation)
# One of these key settings must be provided:
SKY_SUBSCRIPTION_KEYS=primary_key,secondary_key
# or
# SKY_SUBSCRIPTION_KEY=
# SKY_SUBSCRIPTION_KEY_PRIMARY=
# SKY_SUBSCRIPTION_KEY_SECONDARY=

# Access token (short-lived) or refresh trio for auto-refresh
SKY_ACCESS_TOKEN=
SKY_CLIENT_ID=
SKY_CLIENT_SECRET=
SKY_REFRESH_TOKEN=

# Optional: write short‑lived SKY tokens to a separate runtime env file
# so your base .env is not modified by refreshes during development.
# If set, the refresh script writes to this file and server.js reloads it.
# Example:
# SKY_ENV_FILE=.env.runtime

# Logging
# Levels: error, warn, info, debug
LOG_LEVEL=debug

# Validation pacing (ms between member validations)
# Default is fast in dev (0ms) and 250ms otherwise. Override here if needed.
VALIDATION_PACING_MS=

# SKY token auto-refresh
# The scheduler auto-plans the next refresh for (exp - skew).
# SKY_REFRESH_CHECK_INTERVAL_MS is only a fallback when expiry can't be decoded.
SKY_REFRESH_CHECK_INTERVAL_MS=60000
# Refresh when <= this many seconds remain on the access token
SKY_REFRESH_SKEW_SECONDS=300

# Admin Alerts table (Airtable) for critical events like invalid_grant on SKY refresh
ADMIN_ALERTS_TABLE_ID=tblWd85LhYxtHUXDf
